---
const base = import.meta.env.BASE_URL;
---

<section class="py-24 sm:py-36 text-center border-b border-(--color-border) relative overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="w-[600px] h-[600px] bg-(--color-accent)/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 relative">
    <!-- Journal Name -->
    <h1 class="text-7xl sm:text-9xl font-black tracking-[0.15em] text-(--color-accent) mb-4 drop-shadow-lg" style="font-family: var(--font-serif);">
      DAMN
    </h1>
    <p class="text-2xl sm:text-4xl font-bold text-(--color-text-primary) mb-4" style="font-family: var(--font-serif);">
      《彻诞》
    </p>
    <p class="text-base sm:text-lg text-(--color-text-secondary) tracking-[0.15em] mb-10">
      <span class="text-amber-400 font-bold">D</span>iscovery and <span class="text-amber-400 font-bold">A</span>dvancement of <span class="text-amber-400 font-bold">M</span>odern <span class="text-amber-400 font-bold">N</span>ature
    </p>

    <!-- Divider -->
    <div class="flex items-center justify-center gap-4 mb-10">
      <span class="h-px w-16 bg-(--color-border)"></span>
      <span class="text-(--color-accent) text-xs">◆</span>
      <span class="h-px w-16 bg-(--color-border)"></span>
    </div>

    <!-- Taglines -->
    <div class="space-y-3 mb-14">
      <p class="text-xl sm:text-2xl font-bold text-(--color-text-primary) tracking-wide" style="font-family: var(--font-serif);">
        彻古今之变，诞闻所未闻
      </p>
      <p class="text-sm sm:text-base text-(--color-text-secondary)">
        Truth fades, but DAMN lasts forever.
      </p>
    </div>

    <!-- CTA -->
    <a
      href={`${base}submit/`}
      class="inline-block px-10 py-4 bg-(--color-accent) text-white text-base font-bold rounded-lg hover:bg-(--color-accent-hover) transition-all no-underline hover:text-white tracking-wide shadow-lg shadow-(--color-accent)/20 hover:shadow-(--color-accent)/40 hover:scale-105"
    >
      投稿指南 / Submit Your Research
    </a>
  </div>
</section>
